mod cpu Main {
  fn main() {
    data_bind_core(2);
    let handles: HandleTable = data_handle_table("host=cpu0", "fabric=fabric0");
    let source: i64 = 99;
    let pipe: Pipe<i64> = data_output_pipe(source);
    let ready: Marker = data_marker("window_ready");
    let slice: Window<i64> = data_immutable_window(source, 0, 1);
    let copy: Window<i64> = data_copy_window(source, 0, 1);
    print(source);
  }
}
