yir 0.1

resource cpu0 cpu.arm64

cpu.const a cpu0 20
cpu.const b cpu0 6
cpu.div q cpu0 a b
cpu.rem r cpu0 a b
cpu.neg neg_r cpu0 r
cpu.not inv_q cpu0 q
cpu.add total cpu0 neg_r inv_q
cpu.print out cpu0 total

edge dep a q
edge dep b q
edge dep a r
edge dep b r
edge dep r neg_r
edge dep q inv_q
edge dep neg_r total
edge dep inv_q total
edge dep total out
edge effect total out
