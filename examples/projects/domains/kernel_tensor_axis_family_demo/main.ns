use kernel KernelUnit;

mod cpu Main {
  fn main() {
    let input = kernel_tensor(2, 3, "2,4,6,1,3,5");
    let row_max = kernel_reduce_max_axis(input, "rows");
    let col_mean = kernel_reduce_mean_axis(input, "cols");
    let row_pick: i64 = kernel_element_at(row_max, 0, 1);
    let col_pick: i64 = kernel_element_at(col_mean, 0, 2);

    print(row_pick + col_pick);
  }
}
