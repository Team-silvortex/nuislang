mod cpu Main {
  fn apply(x: i64, f: Fn1<i64, i64>) -> i64 {
    return f(x);
  }

  fn main() -> i64 {
    let state: i64 = 2;
    while state > 0 {
      match apply(state, |x: i64| -> i64 {
        return x + 1;
      }) {
        3 => {
          return 7;
        },
        _ => {
          return 9;
        }
      }
    }
    return 0;
  }
}
