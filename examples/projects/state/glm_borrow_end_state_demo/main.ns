mod cpu Main {
  fn main() -> i64 {
    let head: ref Node = move(alloc_node(10, null()));
    let head_ref: ref Node = borrow(head);
    let current: i64 = head_ref.value;
    borrow_end(head_ref);
    head.value = current + 67;
    let updated: i64 = head.value;
    free(head);
    return updated;
  }
}
