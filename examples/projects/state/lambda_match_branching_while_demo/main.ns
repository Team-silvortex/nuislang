mod cpu Main {
  @inline
  fn hot(value: i64) -> bool {
    return value > 2;
  }

  fn main() -> i64 {
    let value: i64 = 0;
    let acc: i64 = 0;
    while value < 5 {
      let value: i64 = value + 1;
      match hot(value) {
        true => {
          let acc: i64 = acc + value;
        },
        _ => {
          let acc: i64 = acc + 0;
        }
      }
    }
    print(acc);
    return acc;
  }
}
