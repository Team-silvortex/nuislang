mod cpu Main {
  fn main() -> i64 {
    let ready: bool = true;
    let armed: bool = false;
    while 1 == 1 {
      match 2 {
        1 if armed => {
          return 5;
        }
        2 if ready => {
          return 7;
        }
        _ => {
          return 9;
        }
      }
    }
    return 0;
  }
}
