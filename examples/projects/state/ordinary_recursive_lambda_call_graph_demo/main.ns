mod cpu Main {
  fn apply(x: i64, f: Fn1<i64, i64>) -> i64 {
    return f(x);
  }

  fn odd(value: i64) -> i64 {
    if value == 0 {
      return 0;
    }
    return even(apply(value, |v: i64| -> i64 { return v - 1; }));
  }

  fn even(value: i64) -> i64 {
    if value == 0 {
      return 1;
    }
    return odd(apply(value, |v: i64| -> i64 { return v - 1; }));
  }

  fn main() -> i64 {
    return even(4);
  }
}
