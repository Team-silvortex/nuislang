mod cpu Main {
  @inline
  fn hot(value: i64) -> bool {
    return value < 3;
  }

  fn main() -> i64 {
    let value: i64 = 0;
    let acc: i64 = 0;
    while value < 6 {
      let value: i64 = value + 1;
      match hot(value) {
        true => {
          continue;
        },
        _ => {}
      }
      if value > 4 {
        let acc: i64 = acc + value;
      } else {
        let acc: i64 = acc + 0;
      }
    }
    print(acc);
    return acc;
  }
}
