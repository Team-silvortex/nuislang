      nova_checkpoint_packet(panel_toggle_state, panel_focus_index, packed_speed, panel_accent);
    let checkpoint_state: NovaCheckpointState =
      nova_checkpoint_state(panel_checkpoint);
    let panel_checkpoint_anchor: i64 =
      nova_checkpoint_state_anchor(checkpoint_state);
    let list_selection_origin: i64 = nova_selection_state_origin(list_selection);
    let table_selection_origin: i64 = nova_selection_state_origin(table_selection);
    let tree_selection_origin: i64 = nova_selection_state_origin(tree_selection);
    let inspector_selection_origin: i64 = nova_selection_state_origin(inspector_selection);
    let outline_selection_origin: i64 = nova_selection_state_origin(outline_selection);
    let panel_state_mix: i64 =
      speed_slider_disabled
      + panel_input_dirty
      + panel_select_committed
      + panel_checkbox_checked
      + panel_radio_disabled
      + panel_textarea_dirty
      + panel_tabs_compact
      + panel_list_dense
      + panel_table_selected_row
      + panel_tree_expanded
      + panel_inspector_pinned
      + panel_outline_collapsed
      + panel_theme_contrast
      + panel_surface_density
      + panel_viewport_width
      + panel_layer_visibility
      + panel_scene_lights
      + panel_camera_zoom
      + panel_material_emissive
      + panel_light_intensity
      + panel_mesh_vertices
      + panel_transform_scale
      + panel_node_depth
      + panel_scene_link_mesh
      + panel_instance_count
      + panel_scene_graph_nodes
      + panel_scene_node_child
      + panel_instance_group_visible
      + panel_scene_cluster_budget
      + panel_visibility_nodes
      + panel_cull_kept
      + panel_lod_active
      + panel_streaming_resident
      + panel_residency_committed
      + panel_eviction_levels
      + panel_prefetch_requested
      + panel_budget_total
      + panel_pressure_level
      + panel_thermal_level
      + panel_power_level
      + panel_latency_frame
      + panel_frame_pacing_cadence
      + panel_jank_spikes
      + panel_pass_samples
      + panel_frame_exposure
      + panel_target_msaa
      + panel_frame_graph_passes
      + panel_attachment_format
      + panel_pass_chain_stages
      + panel_barrier_flush
      + panel_resource_residency
      + panel_schedule_budget
      + panel_submission_batches
      + panel_queue_budget
      + panel_semaphore_scope
      + panel_timeline_epoch
      + panel_fence_scope
      + panel_signal_phase
      + panel_event_route
      + panel_dispatch_lane
      + panel_feedback_status
      + panel_intent_target
      + panel_reaction_result
      + panel_outcome_final
      + panel_resolution_commit
      + panel_commit_applied
      + panel_snapshot_source
      + panel_checkpoint_anchor
      + list_selection_origin
      + table_selection_origin
      + tree_selection_origin
      + inspector_selection_origin
      + outline_selection_origin;

    let render_controls: NovaPanelPacket = nova_panel_from_parts(
      panel_header,
      panel_sliders,
      panel_toggle,
      panel_progress,
      panel_meter,
      panel_button,
      panel_text_input,
      panel_select,
      panel_checkbox,
      panel_radio,
      panel_textarea,
      panel_tabs,
      panel_list,
      panel_table,
      panel_tree,
      panel_inspector,
      panel_outline,
      panel_theme,
      panel_surface,
      panel_viewport,
      panel_layer,
      panel_scene,
      panel_camera,
      panel_material,
      panel_light,
      panel_mesh,
      panel_transform,
      panel_node,
      panel_scene_link,
      panel_instance,
      panel_scene_graph,
      panel_scene_node,
      panel_instance_group,
      panel_scene_cluster,
      panel_visibility,
      panel_cull,
      panel_lod,
      panel_streaming,
      panel_residency,
      panel_eviction,
      panel_prefetch,
      panel_budget,
      panel_pressure,
      panel_thermal,
      panel_power,
      panel_latency,
      panel_frame_pacing,
      panel_jank,
      panel_pass,
      panel_frame,
      panel_target,
      panel_frame_graph,
      panel_attachment,
      panel_pass_chain,
      panel_barrier,
      panel_resource_set,
      panel_schedule,
      panel_submission,
      panel_queue,
      panel_semaphore,
      panel_timeline,
      panel_fence,
      panel_signal,
      panel_event,
      panel_dispatch,
      panel_feedback,
      panel_intent,
      panel_reaction,
      panel_outcome,
      panel_resolution,
      panel_commit,
      panel_snapshot,
      panel_checkpoint,
      panel_focus
    );

    data_profile_bind_core("FabricPlane");
    let fabric_handles: HandleTable<FabricPlaneBindings> =
      data_profile_handle_table("FabricPlane");
    let gpu_packet: Window<NovaPanelPacket> =
      data_profile_send_uplink("FabricPlane", render_controls);
    let frame: Frame = shader_profile_render("SurfaceShader", gpu_packet);

    let host_frame: Window<Frame> = data_profile_send_downlink("FabricPlane", frame);

    print(panel_state_mix);
    cpu_present_frame(host_frame);
  }
}
