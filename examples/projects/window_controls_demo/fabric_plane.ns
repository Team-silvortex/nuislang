mod data FabricPlane {
  fn profile() {
    const window_offset: i64 = 0;
    const uplink_len: i64 = 1;
    const downlink_len: i64 = 1;
    data_bind_core(1);
    let profile_handles: HandleTable = data_handle_table("host=cpu0", "render=shader0");
    let cpu_to_shader: Marker = data_marker("cpu_to_shader");
    let shader_to_cpu: Marker = data_marker("shader_to_cpu");
    let uplink_window: Window = data_immutable_window(window_offset, window_offset, uplink_len);
    let downlink_window: Window = data_copy_window(window_offset, window_offset, downlink_len);
  }
}
