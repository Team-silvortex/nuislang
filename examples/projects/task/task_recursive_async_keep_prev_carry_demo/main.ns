mod cpu Main {
  async fn accumulate(current: i64, acc: i64) -> i64 {
    if current <= 1 {
      return acc;
    }
    if current > 2 {
      return await accumulate(current - 1, acc + current);
    } else {
      return await accumulate(current - 1, acc);
    }
  }

  async fn main() -> i64 {
    return await accumulate(4, 0);
  }
}
