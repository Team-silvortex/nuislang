mod cpu Main {
  type IntThread = Thread<i64>;
  type IntTaskResult = TaskResult<i64>;
  type IntMutex = Mutex<i64>;
  type IntMutexGuard = MutexGuard<i64>;

  struct MutexSnapshot<T> {
    value: T,
    lock: Mutex<T>
  }

  async fn ping(seed: i64) -> i64 {
    return seed + 9;
  }

  fn mutex_snapshot<T>(lock: Mutex<T>) -> MutexSnapshot<T> {
    let guard: MutexGuard<T> = mutex_lock(lock);
    let value: T = mutex_value(guard);
    let reopened: Mutex<T> = mutex_unlock(guard);
    return MutexSnapshot {
      value: value,
      lock: reopened
    };
  }

  fn join_thread_result<T>(worker: Thread<T>) -> TaskResult<T> {
    return thread_join_result(worker);
  }

  fn join_thread_value<T>(worker: Thread<T>) -> T {
    return thread_join(worker);
  }

  fn compute_total(seed: i64) -> i64 {
    let first_snapshot: MutexSnapshot<i64> = mutex_snapshot(mutex_new(seed + 3));
    let first_read: i64 = first_snapshot.value;
    let second_snapshot: MutexSnapshot<i64> = mutex_snapshot(first_snapshot.lock);
    let second_read: i64 = second_snapshot.value;

    let worker: IntThread = thread_spawn(ping(second_read));
    let joined: IntTaskResult = join_thread_result(worker);

    if task_completed(joined) {
      return first_read + second_read + task_value(joined);
    }

    return 0;
  }

  fn compute_direct_join_total(seed: i64) -> i64 {
    let first_snapshot: MutexSnapshot<i64> = mutex_snapshot(mutex_new(seed + 3));
    let first_read: i64 = first_snapshot.value;
    let second_snapshot: MutexSnapshot<i64> = mutex_snapshot(first_snapshot.lock);
    let second_read: i64 = second_snapshot.value;

    let worker: IntThread = thread_spawn(ping(second_read));
    let thread_value: i64 = join_thread_value(worker);
    return first_read + second_read + thread_value;
  }

  test("thread_mutex_join_result") fn thread_mutex_join_result() -> i64 {
    if compute_total(5) == 33 {
      return 1;
    }

    return 0;
  }

  test("thread_mutex_join_direct") fn thread_mutex_join_direct() -> i64 {
    if compute_direct_join_total(5) == 33 {
      return 1;
    }

    return 0;
  }
}
