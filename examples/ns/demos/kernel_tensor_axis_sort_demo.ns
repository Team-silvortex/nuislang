mod cpu Main {
  fn main() {
    let input = kernel_tensor(2, 3, "6,2,4,5,1,3");
    let sorted_rows = kernel_sort_axis(input, "rows");
    let pick: i64 = kernel_element_at(sorted_rows, 0, 1);

    print(pick);
  }
}

mod kernel KernelUnit {
  fn profile() {
    const bind_core: i64 = 2;
    const queue_depth: i64 = 8;
    const batch_lanes: i64 = 16;
    let profile_entry: Unit = kernel_target_config("apple_ane", "coreml", batch_lanes);
  }
}
