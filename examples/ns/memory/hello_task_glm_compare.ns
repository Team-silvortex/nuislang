mod cpu Main {
  async fn ping() -> i64 {
    return 7;
  }

  fn main() -> i64 {
    let direct_task: Task<i64> = timeout(spawn(ping()), 16);
    let direct_value: i64 = join(direct_task);

    let observed_task: Task<i64> = timeout(spawn(ping()), 16);
    let observed_result: TaskResult<i64> = join_result(observed_task);
    if task_completed(observed_result) {
      return direct_value + task_value(observed_result);
    }
    return direct_value;
  }
}
