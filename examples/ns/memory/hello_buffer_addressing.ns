mod cpu Main {
  fn main() {
    let scratch: ref Buffer = alloc_buffer(4, 0);
    scratch[0] = 7;
    scratch[1] = 11;
    scratch[2] = scratch[0] + scratch[1];
    scratch[3] = scratch[2] + 5;
    let staged_sum: i64 = scratch[2];
    let final_value: i64 = scratch[3];
    print(staged_sum + final_value);
  }
}
