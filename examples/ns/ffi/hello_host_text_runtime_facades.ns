mod cpu Main {
  extern "c" @host_symbol("text.len") fn text_len(text_handle: i64) -> i64;
  extern "c" @host_symbol("text.concat") fn text_concat(lhs_handle: i64, rhs_handle: i64) -> i64;
  extern "c" @host_symbol("text.concat_len") fn text_concat_len(lhs_handle: i64, rhs_handle: i64) -> i64;

  struct HostTextFacadeSummary {
    lhs_len: i64,
    rhs_len: i64,
    merged_handle: i64,
    merged_len: i64
  }

  fn capture_host_text_facade(lhs_handle: i64, rhs_handle: i64) -> HostTextFacadeSummary {
    return HostTextFacadeSummary {
      lhs_len: text_len(lhs_handle),
      rhs_len: text_len(rhs_handle),
      merged_handle: text_concat(lhs_handle, rhs_handle),
      merged_len: text_concat_len(lhs_handle, rhs_handle)
    };
  }

  fn main() {
    let summary: HostTextFacadeSummary = capture_host_text_facade(11, 19);
    print(summary.lhs_len + summary.rhs_len + summary.merged_handle + summary.merged_len);
  }
}
