mod cpu Main {
  extern "c" fn host_error_code(kind_handle: i64) -> i64;
  extern "c" fn host_error_message(kind_handle: i64) -> i64;
  extern "c" fn host_error_severity(kind_handle: i64) -> i64;

  enum ErrorSeverity {
    Info,
    Warning,
    Error,
  }

  enum ErrorFamily {
    Unknown,
    InputValidation,
    ResultRuntime,
    DiagnosticRuntime,
  }

  enum Result<T, E> {
    Ok(T),
    Err(E),
  }

  struct ErrorCode {
    kind_handle: i64,
    stable_code: i64,
    message_handle: i64,
    severity_code: i64,
    family_code: i64,
    retryable: i64
  }

  struct DiagnosticCode {
    message_handle: i64,
    severity_code: i64,
    family_code: i64
  }

  struct ErrorEnvelope {
    error: ErrorCode,
    diagnostic: DiagnosticCode
  }

  struct ErrorBridgeSeed {
    primary_kind_handle: i64,
    secondary_kind_handle: i64
  }

  struct ErrorBridgeSummary {
    primary_score: i64,
    secondary_score: i64
  }

  fn kind_invalid_input() -> i64 {
    return 1101;
  }

  fn kind_result_missing() -> i64 {
    return 1202;
  }

  fn kind_diagnostic_message() -> i64 {
    return 1303;
  }

  fn severity_code(severity: ErrorSeverity) -> i64 {
    match severity {
      ErrorSeverity.Info => {
        return 1;
      }
      ErrorSeverity.Warning => {
        return 2;
      }
      ErrorSeverity.Error => {
        return 3;
      }
      _ => {
        return 0;
      }
    }
  }

  fn family_code(family: ErrorFamily) -> i64 {
    match family {
      ErrorFamily.Unknown => {
        return 0;
      }
      ErrorFamily.InputValidation => {
        return 11;
      }
      ErrorFamily.ResultRuntime => {
        return 12;
      }
      ErrorFamily.DiagnosticRuntime => {
        return 13;
      }
      _ => {
        return 0;
      }
    }
  }

  fn classify_error_severity(kind_handle: i64) -> ErrorSeverity {
    if kind_handle == kind_invalid_input() {
      return ErrorSeverity.Error;
    }
    if kind_handle == kind_result_missing() {
      return ErrorSeverity.Warning;
    }
    if kind_handle == kind_diagnostic_message() {
      return ErrorSeverity.Warning;
    }
    return ErrorSeverity.Info;
  }

  fn classify_error_family(kind_handle: i64) -> ErrorFamily {
    if kind_handle == kind_invalid_input() {
      return ErrorFamily.InputValidation;
    }
    if kind_handle == kind_result_missing() {
      return ErrorFamily.ResultRuntime;
    }
    if kind_handle == kind_diagnostic_message() {
      return ErrorFamily.DiagnosticRuntime;
    }
    return ErrorFamily.Unknown;
  }

  fn classify_error_retryable(kind_handle: i64) -> i64 {
    if kind_handle == kind_result_missing() {
      return 1;
    }
    return 0;
  }

  fn build_error_code(kind_handle: i64) -> ErrorCode {
    let family: ErrorFamily = classify_error_family(kind_handle);
    return ErrorCode {
      kind_handle: kind_handle,
      stable_code: host_error_code(kind_handle),
      message_handle: host_error_message(kind_handle),
      severity_code: host_error_severity(kind_handle),
      family_code: family_code(family),
      retryable: classify_error_retryable(kind_handle)
    };
  }

  fn build_diagnostic_code(kind_handle: i64) -> DiagnosticCode {
    let severity: ErrorSeverity = classify_error_severity(kind_handle);
    let family: ErrorFamily = classify_error_family(kind_handle);
    return DiagnosticCode {
      message_handle: host_error_message(kind_handle),
      severity_code: severity_code(severity),
      family_code: family_code(family)
    };
  }

  fn build_error_envelope(kind_handle: i64) -> ErrorEnvelope {
    return ErrorEnvelope {
      error: build_error_code(kind_handle),
      diagnostic: build_diagnostic_code(kind_handle)
    };
  }

  fn lift_error_kind(kind_handle: i64) -> Result<i64, ErrorEnvelope> {
    return Result.Err(build_error_envelope(kind_handle));
  }

  fn result_is_ok<T, E>(result: Result<T, E>) -> bool {
    match result {
      Result.Ok(_) => {
        return true;
      }
      Result.Err(_) => {
        return false;
      }
    }
  }

  fn result_is_err<T, E>(result: Result<T, E>) -> bool {
    return !result_is_ok(result);
  }

  fn result_unwrap_or<T, E>(result: Result<T, E>, fallback: T) -> T {
    match result {
      Result.Ok(value) => {
        return value;
      }
      Result.Err(_) => {
        return fallback;
      }
    }
  }

  fn result_map<T, R, E>(result: Result<T, E>, mapper: Fn1<T, R>) -> Result<R, E> {
    match result {
      Result.Ok(value) => {
        return Result.Ok(mapper(value));
      }
      Result.Err(error) => {
        return Result.Err(error);
      }
    }
  }

  fn result_map_err<T, E, F>(result: Result<T, E>, mapper: Fn1<E, F>) -> Result<T, F> {
    match result {
      Result.Ok(value) => {
        return Result.Ok(value);
      }
      Result.Err(error) => {
        return Result.Err(mapper(error));
      }
    }
  }

  fn raise_value(value: i64) -> i64 {
    return value + 5;
  }

  fn soften_error(envelope: ErrorEnvelope) -> ErrorEnvelope {
    if envelope.error.retryable == 1 {
      return envelope;
    }
    return build_error_envelope(kind_diagnostic_message());
  }

  fn result_score(result: Result<i64, ErrorEnvelope>) -> i64 {
    match result {
      Result.Ok(value) => {
        return value;
      }
      Result.Err(envelope) => {
        return envelope.error.stable_code
          + envelope.error.message_handle
          + envelope.error.severity_code
          + envelope.error.family_code
          + envelope.error.retryable
          + envelope.diagnostic.message_handle
          + envelope.diagnostic.severity_code
          + envelope.diagnostic.family_code;
      }
    }
  }

  fn capture_error_bridge(seed: ErrorBridgeSeed) -> ErrorBridgeSummary {
    let primary: Result<i64, ErrorEnvelope> =
      result_map(lift_error_kind(seed.primary_kind_handle), raise_value);
    let softened_secondary: ErrorEnvelope =
      soften_error(build_error_envelope(seed.secondary_kind_handle));
    let secondary: Result<i64, ErrorEnvelope> =
      Result.Err(softened_secondary);
    return ErrorBridgeSummary {
      primary_score: result_score(primary)
        + result_unwrap_or(primary, -10)
        + if result_is_ok(primary) { 1 } else { 0 },
      secondary_score: result_score(secondary)
        + result_unwrap_or(secondary, -20)
        + if result_is_err(secondary) { 2 } else { 0 }
    };
  }

  fn summarize_error_bridge_recipe(primary_kind_handle: i64, secondary_kind_handle: i64) -> i64 {
    let summary: ErrorBridgeSummary = capture_error_bridge(ErrorBridgeSeed {
      primary_kind_handle: primary_kind_handle,
      secondary_kind_handle: secondary_kind_handle
    });
    return summary.primary_score + summary.secondary_score;
  }

  fn main() {
    print(summarize_error_bridge_recipe(kind_invalid_input(), kind_result_missing()));
  }
}
