    session_value: i64
  }

  struct NetHttpishExchangeSessionSummary {
    session_value: i64
  }

  struct NetSessionSummary {
    argv_count: i64,
    bind_core: i64,
    endpoint_kind: i64,
    timeout_budget: i64,
    retry_budget: i64,
    control_session_value: i64,
    transport_session_value: i64,
    owned_transport_session_value: i64,
    protocol_session_value: i64,
    datagram_session_value: i64,
    owned_datagram_session_value: i64,
    datagram_exchange_session_value: i64,
    datagram_pipeline_value: i64,
    dnsish_exchange_session_value: i64,
    owned_dnsish_exchange_session_value: i64,
    dnsish_pipeline_value: i64,
    owned_dnsish_pipeline_value: i64,
    http_client_session_value: i64,
    httpish_session_value: i64,
    exchange_session_value: i64,
    result_preview_value: i64,
    result_final_value: i64,
    task_preview_value: i64,
    task_final_value: i64,
    session_value: i64,
    tick_ns: i64
  }

  async fn consume_network_result(result: NetworkResult<i64>) -> i64 {
    if network_config_ready(result) {
      return network_value(result) + 5;
    }
    if network_send_ready(result) {
      return network_value(result) + 50;
    }
    if network_recv_ready(result) {
      return network_value(result) + 15;
    }
    return 0;
  }

  async fn plan_control(seed: i64) -> i64 {
    return seed + 29;
  }

  async fn plan_tx(seed: i64) -> i64 {
    return seed + 17;
  }

  async fn plan_rx(seed: i64) -> i64 {
    return seed + 13;
  }

  async fn plan_session(seed: i64) -> i64 {
    return seed + 31;
  }

  fn encode_completed(result: TaskResult<i64>) -> i64 {
    if task_completed(result) {
      return 1;
    }
    return 0;
  }

  fn encode_value(result: TaskResult<i64>) -> i64 {
    if task_completed(result) {
      return task_value(result);
    }
    return 0;
  }

  fn encode_result_value(result: NetworkResult<i64>) -> i64 {
    return network_value(result);
  }

  fn encode_send_ready(result: NetworkResult<i64>) -> i64 {
    if network_send_ready(result) {
      return 1;
    }
    return 0;
  }

  fn encode_recv_ready(result: NetworkResult<i64>) -> i64 {
    if network_recv_ready(result) {
      return 1;
    }
    return 0;
  }

  fn capture_net_control_session_summary() -> NetControlSessionSummary {
    let argv_count: i64 = host_argv_count();
    let local_port_value: i64 = network_profile_local_port("NetworkUnit");
    let local_port: NetworkResult<i64> =
      network_result(network_profile_local_port("NetworkUnit"));
    let remote_port: NetworkResult<i64> =
      network_result(network_profile_remote_port("NetworkUnit"));
    let connect_timeout: NetworkResult<i64> =
      network_result(network_profile_connect_timeout("NetworkUnit"));
    let read_timeout: NetworkResult<i64> =
      network_result(network_profile_read_timeout("NetworkUnit"));
    let write_timeout: NetworkResult<i64> =
      network_result(network_profile_write_timeout("NetworkUnit"));
    let close_result: NetworkResult<i64> = network_result(host_network_close(local_port_value));

    return NetControlSessionSummary {
      session_value: argv_count
        + encode_result_value(local_port)
        + encode_result_value(remote_port)
        + encode_result_value(connect_timeout)
        + encode_result_value(read_timeout)
        + encode_result_value(write_timeout)
        + encode_result_value(close_result)
    };
  }

  fn capture_net_transport_session_summary() -> NetTransportSessionSummary {
    let argv_count: i64 = host_argv_count();
    let retry_budget: i64 = network_profile_retry_budget("NetworkUnit");
    let stream_window: i64 = network_profile_stream_window("NetworkUnit");
    let recv_window: i64 = network_profile_recv_window("NetworkUnit");
    let send_window: i64 = network_profile_send_window("NetworkUnit");
    let local_port: i64 = network_profile_local_port("NetworkUnit");
    let remote_port: i64 = network_profile_remote_port("NetworkUnit");
    let send_result: NetworkResult<i64> = network_result(
      host_network_send_probe(stream_window, send_window, remote_port)
    );
    let recv_result: NetworkResult<i64> = network_result(
      host_network_recv_probe(stream_window, recv_window, local_port)
    );

    return NetTransportSessionSummary {
      session_value: argv_count
        + retry_budget
        + stream_window
        + recv_window
        + send_window
        + local_port
        + remote_port
        + encode_result_value(send_result)
        + encode_result_value(recv_result)
    };
  }

