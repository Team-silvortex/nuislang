    let final_value: i64 =
      send_value + recv_value + stream_window + recv_window + send_window + retry_budget;
    let close_value: i64 = host_network_close_owned(handle);

    return NetOwnedDnsishPipelineSummary {
      session_value: argv_count
        + retry_budget
        + transport_family
        + protocol_kind
        + protocol_version
        + protocol_header_bytes
        + pipeline_code
        + preview_value
        + final_value
        + close_value
    };
  }

  fn capture_net_datagram_pipeline_summary() -> NetDatagramPipelineSummary {
    let argv_count: i64 = host_argv_count();
    let retry_budget: i64 = network_profile_retry_budget("NetworkUnit");
    let transport_family: i64 = network_profile_transport_family("NetworkUnit");
    let protocol_kind: i64 = network_profile_protocol_kind("NetworkUnit");
    let protocol_version: i64 = network_profile_protocol_version("NetworkUnit");
    let protocol_header_bytes: i64 =
      network_profile_protocol_header_bytes("NetworkUnit");
    let stream_window: i64 = network_profile_stream_window("NetworkUnit");
    let recv_window: i64 = network_profile_recv_window("NetworkUnit");
    let send_window: i64 = network_profile_send_window("NetworkUnit");
    let local_port: i64 = network_profile_local_port("NetworkUnit");
    let remote_port: i64 = network_profile_remote_port("NetworkUnit");
    let send_result: NetworkResult<i64> = network_result(
      host_network_send_probe(stream_window, send_window, remote_port)
    );
    let recv_result: NetworkResult<i64> = network_result(
      host_network_recv_probe(stream_window, recv_window, local_port)
    );
    let pipeline_code: i64 =
      transport_family + protocol_kind + protocol_version + retry_budget;
    let preview_value: i64 =
      encode_send_ready(send_result) + encode_recv_ready(recv_result) + protocol_header_bytes;
    let final_value: i64 =
      encode_result_value(send_result)
        + encode_result_value(recv_result)
        + stream_window
        + recv_window
        + send_window;

    return NetDatagramPipelineSummary {
      session_value: argv_count
        + retry_budget
        + transport_family
        + protocol_kind
        + protocol_version
        + protocol_header_bytes
        + pipeline_code
        + preview_value
        + final_value
    };
  }

  fn capture_net_datagram_exchange_session_summary() -> NetDatagramExchangeSessionSummary {
    let argv_count: i64 = host_argv_count();
    let timeout_budget: i64 = network_profile_timeout_budget("NetworkUnit");
    let retry_budget: i64 = network_profile_retry_budget("NetworkUnit");
    let transport_family: i64 = network_profile_transport_family("NetworkUnit");
    let protocol_kind: i64 = network_profile_protocol_kind("NetworkUnit");
    let protocol_version: i64 = network_profile_protocol_version("NetworkUnit");
    let protocol_header_bytes: i64 =
      network_profile_protocol_header_bytes("NetworkUnit");
    let stream_window: i64 = network_profile_stream_window("NetworkUnit");
    let recv_window: i64 = network_profile_recv_window("NetworkUnit");
    let send_window: i64 = network_profile_send_window("NetworkUnit");
    let local_port: i64 = network_profile_local_port("NetworkUnit");
    let remote_port: i64 = network_profile_remote_port("NetworkUnit");
    let send_result: NetworkResult<i64> = network_result(
      host_network_send_probe(stream_window, send_window, remote_port)
    );
    let recv_result: NetworkResult<i64> = network_result(
      host_network_recv_probe(stream_window, recv_window, local_port)
    );
    let exchange_code: i64 = transport_family + protocol_kind + protocol_version;
    let request_bytes: i64 = protocol_header_bytes + send_window + protocol_version;
    let response_bytes: i64 = protocol_header_bytes + recv_window + retry_budget;

    return NetDatagramExchangeSessionSummary {
      session_value: argv_count
        + retry_budget
        + transport_family
        + protocol_kind
        + protocol_version
        + protocol_header_bytes
        + exchange_code
        + request_bytes
        + response_bytes
        + encode_result_value(send_result)
        + encode_result_value(recv_result)
    };
  }

  fn capture_net_httpish_exchange_session_summary() -> NetHttpishExchangeSessionSummary {
    let argv_count: i64 = host_argv_count();
    let retry_budget: i64 = network_profile_retry_budget("NetworkUnit");
    let protocol_kind: i64 = network_profile_protocol_kind("NetworkUnit");
    let protocol_version: i64 = network_profile_protocol_version("NetworkUnit");
    let protocol_header_bytes: i64 =
      network_profile_protocol_header_bytes("NetworkUnit");
    let stream_window: i64 = network_profile_stream_window("NetworkUnit");
    let recv_window: i64 = network_profile_recv_window("NetworkUnit");
    let send_window: i64 = network_profile_send_window("NetworkUnit");
    let local_port: i64 = network_profile_local_port("NetworkUnit");
    let remote_port: i64 = network_profile_remote_port("NetworkUnit");
    let send_result: NetworkResult<i64> = network_result(
      host_network_send_probe(stream_window, send_window, remote_port)
    );
    let recv_result: NetworkResult<i64> = network_result(
      host_network_recv_probe(stream_window, recv_window, local_port)
    );
    let method_code: i64 = 64 + protocol_kind;
    let status_code: i64 = 200 + protocol_version;
    let request_bytes: i64 =
      protocol_header_bytes + protocol_version + 16 + protocol_header_bytes + send_window;
    let response_bytes: i64 =
      protocol_header_bytes + 12 + protocol_header_bytes + recv_window;

    return NetHttpishExchangeSessionSummary {
      session_value: argv_count
        + retry_budget
        + method_code
        + status_code
        + request_bytes
        + response_bytes
        + encode_result_value(send_result)
        + encode_result_value(recv_result)
    };
  }

  fn capture_net_result_windowed_summary() -> NetResultWindowedSummary {
    let stream_window: i64 = network_profile_stream_window("NetworkUnit");
    let recv_window: i64 = network_profile_recv_window("NetworkUnit");
    let send_window: i64 = network_profile_send_window("NetworkUnit");
    let local_port: i64 = network_profile_local_port("NetworkUnit");
    let remote_port: i64 = network_profile_remote_port("NetworkUnit");

    let config_result: NetworkResult<i64> =
      network_result(network_profile_bind_core("NetworkUnit"));
    let send_result: NetworkResult<i64> = network_result(
      host_network_send_probe(stream_window, send_window, remote_port)
    );
    let recv_result: NetworkResult<i64> = network_result(
      host_network_recv_probe(stream_window, recv_window, local_port)
    );

    let config_task: Task<i64> = spawn(consume_network_result(config_result));
    let send_task: Task<i64> = spawn(consume_network_result(send_result));
    let recv_task: Task<i64> = spawn(consume_network_result(recv_result));

    let config_joined: TaskResult<i64> = join_result(config_task);
    let send_joined: TaskResult<i64> = join_result(send_task);
    let recv_joined: TaskResult<i64> = join_result(recv_task);

    return NetResultWindowedSummary {
      preview_value: encode_completed(config_joined)
        + encode_completed(send_joined)
        + encode_completed(recv_joined),
      final_value: encode_value(config_joined)
        + encode_value(send_joined)
        + encode_value(recv_joined)
    };
  }

  fn capture_net_task_windowed_summary() -> NetTaskWindowedSummary {
    let bind_core: i64 = network_profile_bind_core("NetworkUnit");
    let endpoint_kind: i64 = network_profile_endpoint_kind("NetworkUnit");
    let timeout_budget: i64 = network_profile_timeout_budget("NetworkUnit");
    let retry_budget: i64 = network_profile_retry_budget("NetworkUnit");
    let stream_window: i64 = network_profile_stream_window("NetworkUnit");
    let recv_window: i64 = network_profile_recv_window("NetworkUnit");
    let send_window: i64 = network_profile_send_window("NetworkUnit");

    let control_task: Task<i64> = spawn(
      plan_control(bind_core + endpoint_kind + timeout_budget + retry_budget)
    );
    let tx_task: Task<i64> = spawn(plan_tx(stream_window + send_window));
    let rx_task: Task<i64> = spawn(plan_rx(stream_window + recv_window));

    let control_result: TaskResult<i64> = join_result(control_task);
    let tx_result: TaskResult<i64> = join_result(tx_task);
    let rx_result: TaskResult<i64> = join_result(rx_task);

    return NetTaskWindowedSummary {
      preview_value: encode_completed(control_result)
        + encode_completed(tx_result)
        + encode_completed(rx_result),
      final_value: encode_value(control_result)
        + encode_value(tx_result)
        + encode_value(rx_result)
    };
  }

  fn capture_net_session_summary() -> NetSessionSummary {
    let argv_count: i64 = host_argv_count();
    let bind_core: i64 = network_profile_bind_core("NetworkUnit");
    let endpoint_kind: i64 = network_profile_endpoint_kind("NetworkUnit");
    let timeout_budget: i64 = network_profile_timeout_budget("NetworkUnit");
    let retry_budget: i64 = network_profile_retry_budget("NetworkUnit");
    let control_session_summary: NetControlSessionSummary =
      capture_net_control_session_summary();
    let transport_session_summary: NetTransportSessionSummary =
      capture_net_transport_session_summary();
    let owned_transport_session_summary: NetOwnedTransportSessionSummary =
      capture_net_owned_transport_session_summary();
    let protocol_session_summary: NetProtocolSessionSummary =
      capture_net_protocol_session_summary();
    let datagram_session_summary: NetDatagramSessionSummary =
      capture_net_datagram_session_summary();
    let owned_datagram_session_summary: NetOwnedDatagramSessionSummary =
      capture_net_owned_datagram_session_summary();
    let datagram_exchange_session_summary: NetDatagramExchangeSessionSummary =
      capture_net_datagram_exchange_session_summary();
    let datagram_pipeline_summary: NetDatagramPipelineSummary =
      capture_net_datagram_pipeline_summary();
    let dnsish_exchange_session_summary: NetDnsishExchangeSessionSummary =
      capture_net_dnsish_exchange_session_summary();
    let owned_dnsish_exchange_session_summary: NetOwnedDnsishExchangeSessionSummary =
      capture_net_owned_dnsish_exchange_session_summary();
    let dnsish_pipeline_summary: NetDnsishPipelineSummary =
      capture_net_dnsish_pipeline_summary();
    let owned_dnsish_pipeline_summary: NetOwnedDnsishPipelineSummary =
      capture_net_owned_dnsish_pipeline_summary();
    let http_client_session_summary: NetHttpClientSessionSummary =
      capture_net_http_client_session_summary();
    let httpish_session_summary: NetHttpishSessionSummary =
      capture_net_httpish_session_summary();
    let exchange_session_summary: NetHttpishExchangeSessionSummary =
      capture_net_httpish_exchange_session_summary();
    let result_summary: NetResultWindowedSummary = capture_net_result_windowed_summary();
    let task_summary: NetTaskWindowedSummary = capture_net_task_windowed_summary();
    let session_task: Task<i64> = timeout(
      spawn(
        plan_session(
          argv_count
            + bind_core
            + endpoint_kind
            + retry_budget
            + control_session_summary.session_value
            + transport_session_summary.session_value
            + owned_transport_session_summary.session_value
            + protocol_session_summary.session_value
            + datagram_session_summary.session_value
            + owned_datagram_session_summary.session_value
            + datagram_exchange_session_summary.session_value
            + datagram_pipeline_summary.session_value
            + dnsish_exchange_session_summary.session_value
            + owned_dnsish_exchange_session_summary.session_value
            + dnsish_pipeline_summary.session_value
            + owned_dnsish_pipeline_summary.session_value
            + http_client_session_summary.session_value
            + httpish_session_summary.session_value
            + exchange_session_summary.session_value
            + result_summary.preview_value
            + result_summary.final_value
            + task_summary.preview_value
            + task_summary.final_value
        )
      ),
      timeout_budget
    );
    let session_result: TaskResult<i64> = join_result(session_task);
    let tick_ns: i64 = host_monotonic_time_ns();

    return NetSessionSummary {
      argv_count: argv_count,
      bind_core: bind_core,
      endpoint_kind: endpoint_kind,
      timeout_budget: timeout_budget,
      retry_budget: retry_budget,
      control_session_value: control_session_summary.session_value,
      transport_session_value: transport_session_summary.session_value,
      owned_transport_session_value: owned_transport_session_summary.session_value,
      protocol_session_value: protocol_session_summary.session_value,
      datagram_session_value: datagram_session_summary.session_value,
      owned_datagram_session_value: owned_datagram_session_summary.session_value,
      datagram_exchange_session_value: datagram_exchange_session_summary.session_value,
      datagram_pipeline_value: datagram_pipeline_summary.session_value,
      dnsish_exchange_session_value: dnsish_exchange_session_summary.session_value,
      owned_dnsish_exchange_session_value:
        owned_dnsish_exchange_session_summary.session_value,
      dnsish_pipeline_value: dnsish_pipeline_summary.session_value,
      owned_dnsish_pipeline_value: owned_dnsish_pipeline_summary.session_value,
      http_client_session_value: http_client_session_summary.session_value,
      httpish_session_value: httpish_session_summary.session_value,
      exchange_session_value: exchange_session_summary.session_value,
      result_preview_value: result_summary.preview_value,
      result_final_value: result_summary.final_value,
      task_preview_value: task_summary.preview_value,
      task_final_value: task_summary.final_value,
      session_value: encode_value(session_result),
      tick_ns: tick_ns
    };
  }

  fn summarize_net_session_recipe() -> i64 {
    let summary: NetSessionSummary = capture_net_session_summary();
    return summary.argv_count
      + summary.bind_core
      + summary.endpoint_kind
      + summary.timeout_budget
      + summary.retry_budget
      + summary.control_session_value
      + summary.transport_session_value
      + summary.owned_transport_session_value
      + summary.protocol_session_value
      + summary.datagram_session_value
      + summary.owned_datagram_session_value
      + summary.datagram_exchange_session_value
      + summary.datagram_pipeline_value
      + summary.dnsish_exchange_session_value
      + summary.owned_dnsish_exchange_session_value
      + summary.dnsish_pipeline_value
      + summary.owned_dnsish_pipeline_value
      + summary.http_client_session_value
      + summary.httpish_session_value
      + summary.exchange_session_value
      + summary.result_preview_value
      + summary.result_final_value
      + summary.task_preview_value
      + summary.task_final_value
      + summary.session_value
      + summary.tick_ns;
  }

  fn main() {
    print(summarize_net_session_recipe());
  }
}
